#!/usr/bin/env bash
set -euo pipefail

query="${1:-}"

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

list_dirs() {
  if [[ -n "${HERDR_ACTIVE_PANE_CWD:-}" ]]; then
    printf '%s\n' "$HERDR_ACTIVE_PANE_CWD"
  fi

  if command_exists zoxide; then
    zoxide query -l
  elif command_exists fd; then
    fd -t d -H -d 3 . "${HOME:-/}" 2>/dev/null
  else
    find "${HOME:-/}" -maxdepth 3 -type d 2>/dev/null
  fi
}

pick_dir() {
  tv \
    --no-sort \
    --hide-help-panel \
    --input-prompt='dir> ' \
    --preview-command 'ls -la {0} 2>/dev/null | head -80' \
    --input "$query"
}

candidates="$(list_dirs | awk 'NF && !seen[$0]++')"
[[ -n "$candidates" ]] || exit 0

dir="$(printf '%s\n' "$candidates" | pick_dir)" || exit 0
[[ -n "$dir" ]] || exit 0

label="${dir##*/}"
exec herdr workspace create --cwd "$dir" --label "${label:-workspace}"
