#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: herdr-sync-server [--delete] HOST [HOST...]

Sync local Herdr config to remote host(s), then reload remote Herdr if running.
Default is non-destructive. Use --delete to mirror local config exactly.
EOF
}

delete_flag=()
hosts=()

for arg in "$@"; do
  case "$arg" in
    --delete)
      delete_flag=(--delete)
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      hosts+=("$arg")
      ;;
  esac
done

if [[ ${#hosts[@]} -eq 0 ]]; then
  usage
  exit 2
fi

src="${HERDR_SYNC_SOURCE:-$HOME/dotfiles/herdr/.config/herdr/}"
if [[ ! -d "$src" ]]; then
  echo "Herdr config source not found: $src" >&2
  exit 1
fi

for host in "${hosts[@]}"; do
  echo "==> $host"
  ssh "$host" 'mkdir -p ~/.config/herdr'
  rsync -av "${delete_flag[@]}" "$src" "$host:~/.config/herdr/"
  ssh "$host" 'herdr server reload-config >/dev/null 2>&1 || true'
done
